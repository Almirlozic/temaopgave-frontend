---
import Layout from "@layouts/Layout.astro";
import CaseStudyArticle from "@components/CaseStudyArticle.astro";
---

<Layout>
  <!-- Banner -->
  <section class="banner">
    <div>
      <span>CASE STUDIES</span>
      <h1>Taxes & Efficiency</h1>
      <p>
        Our achievements reflect the close collaboration between our expert
        teams and our esteemed clientele. We cultivate a workplace that
        champions peak performance and guarantees client satisfaction.
      </p>
    </div>
  </section>
  <CaseStudyArticle />
</Layout>

<style>
  .banner {
    display: grid;
    grid-column: full;
    background-color: var(--color-neutrals-50);
    div {
      --p-inline: 360px;
      --p-block: 100px;
      text-align: center;
      padding-inline: var(--p-inline);
      padding-block: var(--p-block);
      > * {
        padding-block: var(--space, 0.5rem);
      }
      span {
        font-size: var(--step--2);
        color: var(--color-neutrals-900);
      }
      h1 {
        font-size: var(--step-4);
        font-weight: var(--bold-font);
      }
      p {
        font-size: var(--step--1);
        padding-inline: 100px;
      }
    }
  }
</style>
