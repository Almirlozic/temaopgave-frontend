---
import CheckmarkComponent from "@components/checkmarkComponent.astro";
import CoreValues from "@components/coreValues.astro";
import Herotext from "@components/Herotext.astro";
import ServiceHeader from "@components/ServiceHeader.astro";
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import aboutImage from "@data/images/about.jpg";
import Accordion from "@components/Accordion.astro";
---

<Layout>
  <Herotext
    eyebrow="About"
    title="Igniting Innovation"
    text="Our strength lies in the collaboration between our talented teams and esteemed clients. We cultivate a workplace that champions innovation, promotes peak performance, and guarantees client satisfaction."
  />

  <!-- Grid sektion -->
  <section class="vision-grid">
    <div class="text-column">
      <ServiceHeader
        eyebrow="OUR VISION"
        title="Turn your ideas into reality."
        lede="Capitalize on low hanging fruit to identify a ballpark value added activity beta test. Override the digital divide with additional from DevOps."
      />
      <CheckmarkComponent
        firstli="Bring to the table win-win survival strategies to ensure proactive domination. At the end of the day."
        secondli="Capitalize on low hanging fruit to identify a ballpark value added activity to beta test override the digital."
      />
    </div>

    <div class="image-column">
      <Image src={aboutImage} alt="billede af tre personer der studere" />
    </div>
  </section>
  <section class="flex">
    <div class="counter">
      <h3 data-target="1128">0</h3>
      <p>Successful Work</p>
    </div>
    <div class="counter">
      <h3 data-target="908">0</h3>
      <p>Team member</p>
    </div>
    <div class="counter">
      <h3 data-target="258">0</h3>
      <p>Happy Customers</p>
    </div>
    <div class="counter">
      <h3 data-target="564">0</h3>
      <p>Creative Idea</p>
    </div>
  </section>
  <CoreValues
    backgroundColor="var(--color-neutrals-50)"
    textColor="var(--color-neutrals-900)"
  />
  <Accordion />
</Layout>

<style>
  /* Base grid layout */
  .vision-grid {
    display: grid;
    grid-template-columns: repeat(
      12,
      1fr
    ); /* 12 kolonner giver fleksibilitet */
    gap: 5rem;
    align-items: start;
    margin-block: 6rem;
  }

  /* Tekstkolonnen */
  .text-column {
    grid-column: 1 / 7; /* 50% bredde */
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Billedkolonnen */
  .image-column {
    grid-column: 7 / -1;
    position: relative;
    width: 100%;
  }

  .image-column img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 1rem;
  }

  /* Pynt bag billedet */
  .image-column::after {
    content: "";
    position: absolute;
    top: -10%;
    left: 85%;
    width: 8rem;
    height: 8rem;
    background: var(--color-green-400);
    border-radius: 20px;
    z-index: -1;
  }

  /* --------------------------- */
  /* Responsive for mindre skærme */
  @media (max-width: 1024px) {
    .vision-grid {
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .vision-grid {
      grid-template-columns: 1fr; /* stack kolonner */
      gap: 2rem;
    }

    .text-column,
    .image-column {
      grid-column: 1 / -1; /* fylder hele rækken */
    }

    .image-column::after {
      top: -1rem;
      left: 50%;
      transform: translateX(-50%);
    }
  }

  @media (max-width: 480px) {
    .vision-grid {
      gap: 1.5rem;
      margin-block: 3rem;
    }

    .text-column {
      gap: 1rem;
    }
  }
  .flex {
    display: flex;
    justify-content: space-around;
    margin-bottom: 5rem;
    flex-wrap: wrap;
    animation: fadein 4s ease-in;
    h3 {
      font-size: var(--step-3);
      font-weight: var(--bold-font);
    }
    p {
      font-size: var(--step--2);
      color: var(--color-neutrals-700);
    }
  }
  @keyframes fadein {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .flex .counter h3::after {
    content: "+";
    margin-left: 0.25rem;
    color: inherit;
    font-weight: var(--bold-font);
  }
</style>

<script type="module">
  const flexSection = document.querySelector(".flex");
  const counters = document.querySelectorAll(".flex .counter h3");

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        flexSection.classList.add("visible"); // fade + slide
        counters.forEach((counter) => {
          const target = +counter.getAttribute("data-target");
          let count = 0;
          const increment = Math.ceil(target / 250); // hastighed
          const updateCount = () => {
            count += increment;
            if (count < target) {
              counter.textContent = count;
              requestAnimationFrame(updateCount);
            } else {
              counter.textContent = target; // sikre endelig værdi
            }
          };
          requestAnimationFrame(updateCount);
        });
        observer.unobserve(flexSection); // kun én gang
      }
    },
    { threshold: 0.5 },
  );

  observer.observe(flexSection);
</script>
