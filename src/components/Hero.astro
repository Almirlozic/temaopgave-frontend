---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
---

<section class="hero">
  <div class="hero-wrapper">
    <div class="hero-content">
      <span class="background-grid"></span>
      <div class="hero-content-inner">
        <h1>
          <span class="hero-highlight">Empowering Your</span> Business Growth
        </h1>
        <p>
          Discover tailored strategies and expert insights to take your business
          to the next level. Let us help you navigate challenges and achieve
          sustainable success.
        </p>
        <div class="hero-actions">
          <a href="#0">Book a Meeting</a>
          <a href="#0">Learn More</a>
        </div>
      </div>
    </div>
    <div class="CEO-image">
      <Image src={CEOImage} alt="CEO" />
    </div>
  </div>
</section>
<Services class="services" />

<style>
  @layer components {
    /* Hero layout */
    /* Scroll-driven animation fallback variables */
    .hero {
      --hero-image-opacity: 1;
      --hero-image-translate: 0;
      --hero-content-opacity: 1;
      --hero-content-translate: 0;
      padding-inline: 0;
    }
    .hero {
      --hero-image-opacity: 1;
      --hero-image-translate: 0;
      --hero-content-opacity: 1;
      --hero-content-translate: 0;
      position: relative;
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
      isolation: isolate;
    }

    .hero-wrapper {
      grid-column: full;
      display: grid;
      grid-template-columns: subgrid;
      min-height: clamp(32rem, 70vh, 48rem);
      opacity: var(--hero-image-opacity);
      translate: 0 var(--hero-image-translate);
      will-change: transform, opacity;
    }

    /* Hero content */
    .hero-content {
      position: relative;
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full-start / img-start;
      align-items: center;
      background-color: black;
      color: white;
    }

    .hero-content-inner {
      grid-column: content;
      justify-self: start;
      max-width: 42rem;
      padding-block: 4rem;
      display: grid;
      gap: 1.5rem;
      position: relative;
      z-index: 1;
      opacity: var(--hero-content-opacity);
      translate: 0 var(--hero-content-translate);
    }

    .hero-content-inner h1 {
      font-size: 50px;
      line-height: 1.05;
      max-width: 16ch;
      font-weight: 700;
    }

    .hero-content-inner p {
      font-size: 18px;
      line-height: 1.6;
      max-width: 52ch;
      color: var(--color-on-ui-primary-muted);
    }

    .hero-highlight {
      position: relative;
      display: inline-block;
      padding-bottom: 0.15em;
    }

    .hero-highlight::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: calc(-100vw + 100%);
      width: 90vw;
      height: 0.18em;
      background: linear-gradient(
        90deg,
        transparent 0%,
        transparent 60%,
        var(--color-surface-highlight) 100%
      );
      border-radius: 999px;
      z-index: -1;
    }

    .hero-actions {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .hero-content-inner a {
      display: inline-flex;
      align-items: center;
      font-weight: 500;
      padding: 0.75rem 1.5rem;
      border-radius: 999px;
      text-decoration: none;
      width: fit-content;
      transition: transform 0.5s ease;
    }

    .hero-content-inner a:first-of-type:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 8px rgb(from var(--color-neutrals-50) r g b / 0.6);
    }

    .hero-content-inner a:last-of-type:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 8px rgb(from var(--color-yellow-600) r g b / 0.6);
    }

    .hero-content-inner a:first-of-type {
      background-color: var(--color-surface-highlight);
      color: black;
    }

    .hero-content-inner a:last-of-type {
      border: 1px solid white;
      background-color: black;
      color: white;
    }

    /* Hero image */
    .CEO-image {
      grid-column: img-start / full-end;
      grid-row: 1;
      align-self: stretch;
      height: 100%;
    }

    .CEO-image :global(img) {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    /* Background pattern */
    .background-grid {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .background-grid::after {
      content: "";
      position: absolute;
      right: 0;
      bottom: 0;
      width: min(42vw, 32rem);
      height: min(55%, 26rem);
      background:
        conic-gradient(
            from 180deg at 1px 1px,
            var(--color-surface-highlight) 75%,
            var(--color-blue-700-transparent) 0
          ) -1px -1px /
          60px 60px,
        transparent;
      opacity: 0.35;
      mask-image: radial-gradient(
        ellipse at bottom right,
        black 0%,
        black 32%,
        transparent 100%
      );
      -webkit-mask-image: radial-gradient(
        ellipse at bottom right,
        black 0%,
        black 32%,
        transparent 100%
      );
    }

    @supports (animation-timeline: scroll()) {
      .hero {
      }

      .hero-content-inner {
        animation: hero-copy-fade linear both;
        animation-timeline: scroll();
        animation-range: 0 90svh;
      }

      .hero-wrapper {
        animation: hero-image-parallax linear both;
        animation-timeline: scroll();
        animation-range: 0 100svh;
      }
    }

    @keyframes hero-image-parallax {
      from {
        opacity: 1;
        translate: 0 0;
      }

      to {
        opacity: 0.2;
        translate: 0 18svh;
      }
    }

    @keyframes hero-copy-fade {
      from {
        opacity: 1;
        translate: 0 0;
      }

      to {
        opacity: 0;
        translate: 0 8svh;
      }
    }

    /* Services overlap */
    .services {
      position: relative;
      margin-top: -10rem;
      z-index: 2;
    }
  }

  @media (max-width: 768px) {
    .hero-wrapper {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-content {
      grid-column: full;
      grid-row: 2;
      min-height: auto;
    }

    .hero-content-inner {
      padding-block: 2rem;
      padding-inline: 1rem;
      text-align: center;
      justify-self: center;
      max-width: none;
    }

    .hero-content-inner h1 {
      font-size: clamp(2rem, 8vw, 3rem);
      max-width: none;
    }

    .hero-content-inner p {
      font-size: clamp(1rem, 4vw, 1.125rem);
      max-width: none;
    }

    .hero-actions {
      justify-content: center;
      gap: 1rem;
    }

    .hero-content-inner a {
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
    }

    .CEO-image {
      grid-column: full;
      grid-row: 1;
      height: auto;
      min-height: 20rem;
      overflow: clip;
    }

    .background-grid::after {
      width: min(60vw, 20rem);
      height: min(40%, 15rem);
    }

    .services {
      margin-top: 2rem;
    }
  }

  @media (max-width: 480px) {
    .hero-content-inner {
      padding-block: 1rem;
      gap: 1rem;
    }

    .hero-content-inner h1 {
      font-size: 2rem;
    }

    .hero-content-inner p {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .CEO-image {
      min-height: 15rem;
    }
  }
</style>
