---
import Employees from "@data/employees.json";
import { Image } from "astro:assets";
import DynamicImage from "@helpers/DynamicImage.astro";
import InstagramIcon from "@icons/instagram.svg";
import FacebookIcon from "@icons/facebook.svg";
import ServiceHeader from "@components/ServiceHeader.astro";
import HeroText from "@components/Herotext.astro";
---

<section class="hero-full">
  <HeroText
    eyebrow="TEAM"
    title="The consultors"
    text="Our success stems from the synergy between dedicated teams and our valued clients. We prioritize a company culture that fosters exceptional productivity, ensures customer satisfaction."
  />
</section>
<section class="meet-the-team">
  <div class="meet-the-team__intro">
    <div class="meet-the-team__intro-inner">
      <div class="meet-the-team__intro-copy">
        <ServiceHeader
          title="Meet Our Great Team"
          lede="Welcome to our amazing team! We are a group of passionate individuals dedicated to excellence and innovation. Each member brings unique skills and experiences, working together to achieve our goals. Join us as we embark on exciting projects and create lasting impacts."
        />
      </div>

      <div class="cta">
        <button class="cta-button">Get in touch</button>
      </div>
    </div>
  </div>

  <div class="meet-the-team__grid-wrapper">
    <div class="meet-the-team__grid">
      {
        Employees.map((employee) => (
          <article class="employee-card">
            <div class="employee-card__image-wrapper">
              <a
                href={`/${employee.slug}`}
                aria-label={`Read more about ${employee.name}`}
              >
                <DynamicImage
                  imagePath={employee.img}
                  altText={employee.name}
                  class="employee-card__image"
                  style={`view-transition-name: img-${employee.slug};`}
                />
              </a>
            </div>

            <div class="employee-card__content">
              <p class="employee-card__title">{employee.title}</p>
              <h3>{employee.name}</h3>
              <p class="employee-card__description">{employee.description}</p>
              <div class="icons">
                <a href="https://instagram.com" target="_blank">
                  <Image src={InstagramIcon} alt="A picture of a instagram" />
                </a>
                <a href="https://facebook.com" target="_blank">
                  <Image src={FacebookIcon} alt="A picture of a facebook" />
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero-full {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: full;
    width: 100%;
    margin: 2rem;
  }

  .hero-full > :global(*) {
    grid-column: full;
    width: 100%;
    max-width: none !important;
    margin-inline: 0 !important;
    text-align: center !important;
  }

  .hero-full :global(h1),
  .hero-full :global(h2),
  .hero-full :global(h3),
  .hero-full :global(p),
  .hero-full :global(.eyebrow),
  .hero-full :global(.title),
  .hero-full :global(.text) {
    text-align: center !important;
    margin-inline: 0 !important;
    max-width: none !important;
  }
  .meet-the-team {
    display: grid;
    grid-template-columns: subgrid;
    gap: 3rem;
  }

  .meet-the-team__intro {
    grid-column: content;
    width: 100%;
    max-width: none;
  }

  .meet-the-team__intro-inner {
    display: grid;
    grid-template-columns: minmax(0, 60ch) auto;
    gap: 1.5rem;
    align-items: stretch;
    width: 100%;
  }

  .meet-the-team__intro-copy {
    grid-column: 1;
    justify-self: start;
    min-width: 0;
  }

  .meet-the-team__intro-copy :global(.service-header) {
    width: 100%;
  }

  .cta {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    justify-self: end;
    align-self: end;
  }

  .cta-button {
    background: #000;
    color: #fff;
    border: none;
    padding: 0.75rem 1.25rem;
    border-radius: 999px;
    font-size: 0.9rem;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  .meet-the-team__grid-wrapper {
    grid-column: content;
    width: 100%;
    min-width: 0;
    container: team-grid / inline-size;
  }

  .meet-the-team__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 360px));
    gap: 2rem;
    justify-content: center;
    justify-items: stretch;
    min-width: 0;
  }

  @media (max-width: 900px) {
    .meet-the-team__intro-inner {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .meet-the-team__intro-copy {
      grid-column: 1;
      justify-self: start;
      width: 100%;
    }

    .cta {
      grid-column: 1;
      justify-self: start;
      align-self: start;
      width: 100%;
      margin-top: 0.25rem;
    }

    .cta-button {
      align-self: flex-start;
    }

    .meet-the-team__grid {
      grid-template-columns: repeat(2, minmax(0, 340px));
      justify-content: start;
      gap: 6rem;
    }
  }

  .meet-the-team {
    margin: 2rem;
  }
  @media (max-width: 600px) {
    .meet-the-team {
      gap: 2rem;
    }

    .meet-the-team__intro {
      max-width: 100%;
      padding-inline: 1rem;
      text-align: center;
    }

    .meet-the-team__intro-inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
      gap: 1rem;
    }

    .meet-the-team__intro-copy {
      grid-column: 1;
      justify-self: center;
      width: 100%;
    }

    .cta {
      grid-column: 1;
      justify-self: center;
      align-self: start;
      align-items: center;
      width: 100%;
      margin-top: 0.25rem;
    }

    .cta-button {
      align-self: center;
    }

    .meet-the-team__intro :global(.service-header) {
      gap: 0.75rem;
    }

    .meet-the-team__intro :global(h2) {
      font-size: var(--step-1);
      text-wrap: balance;
    }

    .meet-the-team__intro :global(p) {
      font-size: var(--step--1);
      max-width: 32ch;
      margin-inline: auto;
      text-wrap: pretty;
    }

    .meet-the-team__grid {
      grid-template-columns: minmax(0, 320px);
      padding-inline: 1rem;
      justify-content: center;
    }
  }

  .employee-card {
    width: 100%;
    container: employee-card / inline-size;
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 1rem;
    overflow: hidden;
    min-width: 0;
    position: relative;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .employee-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  .employee-card__image-wrapper {
    aspect-ratio: 4 / 3;
  }

  .employee-card__image-wrapper a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .employee-card__image,
  .employee-card__image-wrapper :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .employee-card__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    height: 100%;
  }

  .employee-card__title {
    position: relative;
    z-index: 2;
    margin-inline: auto;
    text-align: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #0b1220;
    color: #fff;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    width: fit-content;
  }

  .employee-card__description {
    font-size: 0.9rem;
    line-height: 1.6;
    opacity: 0.85;

    text-align: center;
    max-width: 28ch;
  }

  .icons,
  .icons a {
    position: relative;
    z-index: 2;
  }

  .icons {
    display: flex;
    flex-direction: row;
    gap: 1rem;
  }

  h3 {
    font-size: var(--step-0);
    font-weight: var(--bold-font);
  }

  p {
    font-size: var(--step--1);
  }

  @container employee-card (max-width: 520px) {
    .employee-card__content {
      padding: 1rem;
      gap: 0.85rem;
    }

    .employee-card__title {
      margin-top: -3.25rem;
      font-size: 0.7rem;
      padding: 0.35rem 0.75rem;
    }

    .employee-card__description {
      font-size: 0.85rem;
      max-width: 30ch;
    }

    h3 {
      font-size: var(--step-0);
    }
  }

  @container employee-card (max-width: 420px) {
    .employee-card__content {
      padding: 0.9rem;
      gap: 0.75rem;
    }

    .employee-card__title {
      align-self: center;
      margin-top: -2.75rem;
      font-size: 0.65rem;
    }

    .employee-card__description {
      font-size: 0.8rem;
      max-width: 26ch;
    }

    .icons {
      gap: 0.75rem;
    }

    h3 {
      font-size: var(--step--1);
    }

    p {
      font-size: var(--step--2);
    }
  }
</style>
