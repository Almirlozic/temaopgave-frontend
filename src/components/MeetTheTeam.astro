---
import Employees from "@data/employees.json";
import { Image } from "astro:assets";
import InstagramIcon from "@icons/instagram.svg";
import FacebookIcon from "@icons/facebook.svg";
---

<section class="meet-the-team">
  <div class="meet-the-team__intro">
    <h2>Meet the team</h2>
    <p>
      Welcome to our amazing team! We are a group of passionate individuals
      dedicated to excellence and innovation. Each member brings unique skills
      and experiences, working together to achieve our goals. Join us as we
      embark on exciting projects and create lasting impacts.
    </p>
  </div>

  <div class="meet-the-team__grid">
    {
      Employees.map((employee) => (
        <article class="employee-card">
          <div class="employee-card__image-wrapper">
            <a
              href={`/${employee.id}`}
              aria-label={`Read more about ${employee.name}`}
            >
              <img
                src={employee.img}
                alt={employee.name}
                class="employee-card__image"
              />
            </a>
          </div>

          <div class="employee-card__content">
            <p class="employee-card__title">{employee.title}</p>
            <h3>{employee.name}</h3>
            <p class="employee-card__description">{employee.description}</p>
            <div class="icons">
              <a href="https://instagram.com" target="_blank">
                <Image src={InstagramIcon} alt="A picture of a instagram" />
              </a>
              <a href="https://facebook.com" target="_blank">
                <Image src={FacebookIcon} alt="A picture of a facebook" />
              </a>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .meet-the-team {
    grid-column: full;
    display: grid;
    grid-template-columns: subgrid;
    gap: 3rem;
  }

  .meet-the-team__intro {
    grid-column: content;
    max-width: 60ch;
  }

  .meet-the-team__grid {
    grid-column: content;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .employee-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 1rem;
    overflow: hidden;
    position: relative;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .employee-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  .employee-card__image-wrapper {
    aspect-ratio: 4 / 3;
  }

  .employee-card__image-wrapper a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .employee-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .employee-card__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    height: 100%;
  }

  .employee-card__title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: -4rem;
    margin-left: auto;
    background: #0b1220;
    color: #fff;

    padding: 0.4rem 0.9rem;
    border-radius: 999px;

    width: fit-content;
  }

  .employee-card__description {
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0.85;

    text-align: center;
    max-width: 32ch;
  }

  .icons,
  .icons a {
    position: relative;
    z-index: 2;
  }

  .icons {
    display: flex;
    flex-direction: row;
    gap: 1rem;
  }

  h3 {
    font-size: var(--step-1);
    font-weight: var(--bold-font);
  }

  p {
    font-size: var(--step--1);
  }
</style>
