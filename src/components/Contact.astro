---
import ServiceHeader from "@components/ServiceHeader.astro";
import { Image } from "astro:assets";
import PhoneIcon from "@icons/phone.svg";
import ClockIcon from "@icons/clock.svg";
import PinIcon from "@icons/pin.svg";
import ContactWoman from "@data/images/Contact-woman.jpg";
import ContactConversation from "@data/images/Contact-conversation.jpg";
import ContactHands from "@data/images/Contact-hands.jpg";
---

<section>
  <div class="column-left">
    <ServiceHeader
      eyebrow="Process"
      title="Contact Us. It’s Easy."
      lede="Leverage agile frameworks to provide a robust synopsis for high level overviews. Iterative approaches to corporate strategy foster collaborative."
    />
    <div class="infoWrapper">
      <div class="CallToday">
        <Image src={PhoneIcon} alt="A picture of a phone" />
        <h3>Call today</h3>
        <p><strong>+1 800 100 900</strong></p>
      </div>
      <div class="Clock">
        <Image src={ClockIcon} alt="A picture of a phone" />
        <h3>Monday to friday</h3>
        <p><strong>9AM - 5PM</strong></p>
      </div>
      <div class="pin">
        <Image src={PinIcon} alt="A picture of a pin" />
        <h3>USA Office</h3>
        <p><strong>195 Devonshire St Boston, MA 02110</strong></p>
      </div>
    </div>
  </div>
  <div class="column-right">
    <div class="ContactWoman">
      <Image src={ContactWoman} alt="A picture of a woman" />
    </div>
    <div class="ContactConversation">
      <Image src={ContactConversation} alt="A couple talking" />
    </div>
    <div class="ContactHands">
      <Image src={ContactHands} alt="Hands" />
    </div>
  </div>
</section>

<style>
  section {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    row-gap: 2rem;
    column-gap: 4rem;
    margin-bottom: 5rem;
  }

  .column-left {
    grid-column: 1;
    display: flex;
    flex-direction: column;
  }

  .infoWrapper {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    margin-top: auto;
    padding-top: 2rem;
    flex: 1;
  }

  .CallToday,
  .Clock,
  .pin {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1rem;
    align-items: center;
  }

  .CallToday {
    --icon-bg: #ffecbb;
    --icon-color: #c6921a;
  }

  .Clock {
    --icon-bg: #a4eda4;
  }

  .pin {
    --icon-bg: #eaeaea;
  }

  .CallToday :global(img),
  .Clock :global(img),
  .pin :global(img) {
    grid-row: 1 / 3;
    inline-size: 3.5rem;
    block-size: 3.5rem;
    padding: 0.85rem;
    border-radius: 999px;
    background-color: var(--icon-bg);
    object-fit: contain;
  }

  .CallToday h3,
  .Clock h3,
  .pin h3 {
    margin: 0;
  }

  .CallToday p,
  .Clock p,
  .pin p {
    margin: 0;
  }

  .column-right {
    grid-column: 2;
    display: grid;
    gap: 2rem;
    grid-template-columns: 1.1fr 1fr;
    grid-template-rows: 1fr 1fr;
    grid-template-areas:
      "ContactWoman ContactConversation"
      "ContactWoman ContactHands";
    align-items: cover;
  }

  .column-right > * {
    min-width: 0;
    height: 100%;
  }

  .column-right > :nth-child(1) {
    grid-area: ContactWoman;
  }

  .column-right > :nth-child(2) {
    grid-area: ContactConversation;
    overflow: hidden;
    border-radius: 1rem;
  }

  .column-right > :nth-child(3) {
    grid-area: ContactHands;
    overflow: hidden;
    border-radius: 1rem;
  }

  .column-right :global(img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ContactWoman {
    position: relative;
  }

  .ContactWoman::after {
    content: "";
    position: absolute;
    width: 220px;
    height: 120px;
    background: var(--color-green-600);
    bottom: -20px;
    left: -40px;
    border-radius: 1rem;
    z-index: 0;
  }

  .ContactWoman :global(img) {
    position: relative;
    z-index: 1;
    border-radius: 1rem;
  }

  @media (max-width: 1024px) {
    section {
      grid-template-columns: 1fr;
      row-gap: 3rem;
      column-gap: 0;
    }

    .column-left {
      order: 2;
    }

    .column-right {
      display: none;
    }

    .infoWrapper {
      gap: 1.5rem;
      padding-top: 1rem;
    }

    .CallToday,
    .Clock,
    .pin {
      column-gap: 0.75rem;
    }

    .CallToday :global(img),
    .Clock :global(img),
    .pin :global(img) {
      inline-size: 3rem;
      block-size: 3rem;
      padding: 0.7rem;
    }
  }

  @media (max-width: 480px) {
    section {
      margin-bottom: 3rem;
    }

    .infoWrapper {
      gap: 1rem;
      padding-top: 0.5rem;
    }

    .CallToday :global(img),
    .Clock :global(img),
    .pin :global(img) {
      inline-size: 2.5rem;
      block-size: 2.5rem;
      padding: 0.5rem;
    }

    .ContactWoman::after {
      width: 150px;
      height: 80px;
      bottom: -10px;
      left: -20px;
    }
  }
</style>
